<!-- 获取要显示的文章 (直接取 Hexo 生成好的 page.posts 并按时间排序) -->
<% var postsToShow = page.posts ? page.posts.sort('-date') : site.posts.sort('-date'); %>

<%
  var archiveTitle = __('post.list');
  if (page.category) {
    archiveTitle = page.category;
  } else if (page.tag) {
    archiveTitle = page.tag;
  } else if (page.archive) {
    if (page.year) {
      archiveTitle = page.year + (page.month ? '-' + page.month : '');
    } else {
      archiveTitle = __('menu.Archive');
    }
  }
%>

<!-- 头部 -->
<%- partial('_partial/header',{}, {cache: true}) %>

<!-- 页面内容 -->
<div class="page-content">
  <div class="sankey-archive-container" style="margin-top: 1.5rem;">
    <div class="sankey-articles-section" style="margin-top: 0;">
      <h3 class="articles-section-title">
        <span class="title-text"><%= archiveTitle %></span>
        <span class="articles-count-badge"><%= __('post.count', postsToShow.length) %></span>
      </h3>
      
      <div class="sankey-articles-list">
        <% postsToShow.each(function(post){ %>
          <%
            // 渲染分类与标签徽章
            var taxHtml = '';
            if (post.categories && post.categories.length > 0) {
              post.categories.forEach(function(cat) {
                taxHtml += '<span class="article-badge category-badge">' + cat.name + '</span>';
              });
            }
            if (post.tags && post.tags.length > 0) {
              post.tags.slice(0, 3).forEach(function(tag) {
                taxHtml += '<span class="article-badge tag-badge">#' + tag.name + '</span>';
              });
            }
          %>
          <a href="<%- url_for(post.path) %>" class="sankey-article-card">
            <div class="article-card-header">
              <h4 class="article-card-title"><%= post.title %></h4>
            </div>
            <div class="article-card-footer">
              <span class="article-date">
                <i class="far fa-calendar-alt"></i> <%= date(post.date, 'YYYY-MM-DD') %>
              </span>
              <div class="article-taxonomies"><%- taxHtml %></div>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<!-- 卡片 GSAP 入场动画及 Hover 微交互 -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap !== 'undefined') {
      const animItems = document.querySelectorAll('.sankey-articles-list .sankey-article-card');
      gsap.fromTo(animItems,
        { opacity: 0, y: 15 },
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.45, 
          stagger: 0.04, 
          ease: 'power2.out',
          overwrite: 'auto'
        }
      );
      
      animItems.forEach(item => {
        item.addEventListener('mouseenter', () => {
          gsap.to(item, {
            y: -4,
            scale: 1.015,
            borderColor: 'var(--secondary-text-color)',
            boxShadow: '0 8px 20px var(--shadow-color1)',
            duration: 0.25,
            ease: 'power2.out'
          });
        });
        item.addEventListener('mouseleave', () => {
          gsap.to(item, {
            y: 0,
            scale: 1,
            borderColor: 'var(--shadow-color1)',
            boxShadow: '0 2px 8px var(--shadow-color2)',
            duration: 0.25,
            ease: 'power2.out'
          });
        });
      });
    }
  });
</script>
