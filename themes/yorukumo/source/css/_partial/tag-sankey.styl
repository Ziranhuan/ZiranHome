// 桑基图归档页面样式
.sankey-archive-container
  width 100%
  display flex
  flex-direction column
  gap 2rem
  margin 1rem 0

  // 1. 控制面板 (Tabs & Filter Info)
  .sankey-controls
    display flex
    flex-wrap wrap
    justify-content space-between
    align-items center
    gap 1.5rem
    padding 1rem 1.5rem
    background var(--main-color)
    border-radius 1rem
    box-shadow 0 2px 8px var(--shadow-color2)
    border 1px solid var(--shadow-color1)

    .sankey-tabs
      display flex
      gap 0.5rem
      flex-wrap wrap

      .sankey-tab
        background transparent
        border 1px solid var(--secondary-text-color)
        color var(--text-color)
        padding 0.5rem 1.2rem
        border-radius 2rem
        cursor pointer
        font-family inherit
        font-size 0.9rem
        font-weight 500
        transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1)

        &:hover
          background var(--shadow-color1)
          transform translateY(-1px)

        &.active
          background var(--text-color)
          color var(--main-color)
          border-color var(--text-color)
          box-shadow 0 4px 10px var(--shadow-color1)

    .sankey-info
      display flex
      align-items center
      gap 0.8rem
      font-size 0.95rem

      .filter-status-label
        color var(--secondary-text-color)

      .active-filter-value
        font-weight bold
        color var(--text-color)
        background var(--shadow-color1)
        padding 0.3rem 0.8rem
        border-radius 0.5rem
        border 1px solid var(--shadow-color2)

      .reset-filter-btn
        background transparent
        border 1px solid var(--text-color)
        color var(--text-color)
        padding 0.3rem 0.8rem
        border-radius 0.5rem
        cursor pointer
        font-family inherit
        font-size 0.85rem
        font-weight 600
        display inline-flex
        align-items center
        gap 0.3rem
        transition all 0.25s ease

        &:hover
          background var(--text-color)
          color var(--main-color)

  // 2. 桑基图画布卡片 (Chart Card)
  .sankey-chart-card
    background var(--main-color)
    border-radius 1.5rem
    padding 1.5rem
    box-shadow 0 4px 20px var(--shadow-color1)
    border 1px solid var(--shadow-color1)
    overflow visible
    position relative
    min-height 400px
    display flex
    flex-direction column
    justify-content center

    #sankey-chart
      width 100%
      height 100%
      position relative

      svg
        overflow visible
        display block

    .sankey-loader
      text-align center
      color var(--secondary-text-color)
      font-size 1.1rem

  // D3 桑基图内部元素样式
  .sankey-node
    rect
      cursor pointer
      rx 4px
      ry 4px
      transition fill-opacity 0.3s, stroke 0.3s, stroke-width 0.3s

      &:hover
        stroke var(--text-color)
        stroke-width 1.5px
        fill-opacity 0.95 !important

    text
      font-family inherit
      font-size 0.85rem
      font-weight 600
      fill var(--text-color)
      pointer-events none
      user-select none
      text-shadow 0 1px 2px var(--main-color), 0 -1px 2px var(--main-color), 1px 0 2px var(--main-color), -1px 0 2px var(--main-color)

    // 筛选状态样式
    &.dimmed
      rect
        fill-opacity 0.15 !important
      text
        opacity 0.25

    &.active
      rect
        stroke var(--text-color)
        stroke-width 2px
        fill-opacity 1 !important
      text
        font-size 0.95rem
        fill var(--text-color)
        text-shadow 0 0 4px var(--main-color)

  .sankey-link
    fill none
    stroke-opacity 0.2
    transition stroke-opacity 0.3s

    &:hover
      stroke-opacity 0.65 !important
      cursor pointer

    &.dimmed
      stroke-opacity 0.04 !important

    &.highlighted
      stroke-opacity 0.65 !important

  // 3. 悬浮提示框 (Tooltip)
  .sankey-tooltip
    position absolute
    z-index 1050
    pointer-events none
    background var(--main-color)
    backdrop-filter blur(10px)
    border 1px solid var(--shadow-color2)
    padding 0.85rem 1.1rem
    border-radius 0.85rem
    box-shadow 0 10px 30px var(--shadow-color2)
    font-size 0.85rem
    color var(--text-color)
    line-height 1.5
    transition opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1)
    opacity 0

    .tooltip-header
      font-weight bold
      margin-bottom 0.5rem
      border-bottom 1px solid var(--shadow-color1)
      padding-bottom 0.4rem
      display flex
      justify-content space-between
      align-items center
      gap 1rem

    .tooltip-body
      font-size 0.8rem
      line-height 1.5
      opacity 0.9

  // 4. 文章列表区域 (Filtered Articles)
  .sankey-articles-section
    margin-top 1rem

    .articles-section-title
      font-size 1.3rem
      font-weight bold
      display flex
      align-items center
      gap 0.8rem
      margin-bottom 1.5rem
      color var(--text-color)

      .articles-count-badge
        font-size 0.9rem
        font-weight normal
        background var(--shadow-color1)
        padding 0.2rem 0.6rem
        border-radius 1rem
        color var(--secondary-text-color)
        border 1px solid var(--shadow-color2)

    .sankey-articles-list
      display grid
      grid-template-columns 1fr
      gap 1rem

      @media (min-width: 768px)
        grid-template-columns repeat(2, 1fr)

      .sankey-article-card
        background var(--main-color)
        border-radius 1rem
        padding 1.25rem
        box-shadow 0 2px 8px var(--shadow-color2)
        border 1px solid var(--shadow-color1)
        display flex
        flex-direction column
        justify-content space-between
        min-height 120px
        transition all 0.3s ease
        text-decoration none
        color inherit

        &:hover
          transform translateY(-4px)
          box-shadow 0 10px 20px var(--shadow-color1)
          border-color var(--secondary-text-color)

        .article-card-header
          margin-bottom 0.75rem

          .article-card-title
            margin 0 0 0.5rem 0
            font-size 1.15rem
            font-weight bold
            line-height 1.4
            color var(--text-color)
            transition color 0.2s ease

          &:hover .article-card-title
            color var(--secondary-text-color)

        .article-card-footer
          display flex
          flex-wrap wrap
          justify-content space-between
          align-items center
          gap 0.5rem
          font-size 0.8rem
          color var(--secondary-text-color)
          margin-top auto

          .article-date
            display flex
            align-items center
            gap 0.3rem

          .article-taxonomies
            display flex
            gap 0.4rem
            flex-wrap wrap

            .article-badge
              background var(--secondary-color)
              padding 0.15rem 0.4rem
              border-radius 0.25rem
              border 1px solid var(--shadow-color1)
              font-size 0.75rem

              &.category-badge
                color var(--text-color)
                font-weight 600

              &.tag-badge
                opacity 0.85
